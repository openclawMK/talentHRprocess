OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o
PORT=3001

# HR auth (Session 12) — secret used to sign JWTs.
JWT_SECRET=peoplequest_secret_2024

# WhatsApp via Twilio (Session 10) — optional; leave blank to disable messaging.
# Get these from the Twilio Console (Messaging → Try it out → WhatsApp sandbox).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Public URL of the deployed frontend, used to build portal links inside messages.
FRONTEND_URL=https://your-app.vercel.app
