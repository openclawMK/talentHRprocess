{
  "meta": {
    "sources": [
      { "id": "DOSM2023", "name": "DOSM Salaries & Wages Survey Report 2023", "url": "https://open.dosm.gov.my/publications/salaries_wages_2023", "type": "official" },
      { "id": "JobStreet2026", "name": "JobStreet Malaysia role salary pages 2026", "url": "https://my.jobstreet.com/career-advice", "type": "platform" },
      { "id": "Industry", "name": "Malaysian F&B/hospitality recruitment market ranges", "type": "industry" }
    ],
    "currency": "MYR",
    "period": "monthly",
    "minimum_wage": 1700,
    "national_median": 2602,
    "regional_damping": 0.6,
    "note": "Role bands are real market figures cross-validated across DOSM (official occupation-group medians) and JobStreet (role-level Malaysian listings), with recruitment-market ranges for manager tiers. DOSM Service & sales median RM1,818 corroborates JobStreet crew ranges (~RM1,900-2,700). Regional multipliers (from DOSM state medians) are damped to 60% to avoid double-counting the location mix already present in platform data. All bands floored at the current minimum wage. Figures are indicative benchmarks, not offers."
  },
  "regional_multipliers": {
    "kuala lumpur": 1.33, "putrajaya": 1.25, "selangor": 1.24, "labuan": 1.05,
    "penang": 1.04, "pulau pinang": 1.04, "johor": 1.0, "melaka": 0.95,
    "negeri sembilan": 0.95, "perak": 0.9, "kedah": 0.88, "pahang": 0.9,
    "terengganu": 0.9, "kelantan": 0.85, "perlis": 0.85, "sabah": 0.88,
    "sarawak": 0.9, "default": 1.0
  },
